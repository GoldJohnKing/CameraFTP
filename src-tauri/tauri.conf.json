{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "com.cameraftp.companion",
  "build": {
    "beforeDevCommand": "bun dev",
    "beforeBuildCommand": "bun run build",
    "frontendDist": "../dist",
    "devUrl": null
  },
  "app": {
    "windows": [
      {
        "title": "图传伴侣",
        "width": 400,
        "height": 700,
        "resizable": true,
        "fullscreen": false,
        "visible": true,
        "skipTaskbar": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all"
  }
}